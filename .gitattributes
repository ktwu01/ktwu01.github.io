# Normalize all text files to LF on commit (cross-platform: Windows CRLF → LF)
* text=auto eol=lf

# Explicitly LF for web/Jekyll source files
*.md text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.js text eol=lf
*.rb text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.txt text eol=lf
*.bib text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
